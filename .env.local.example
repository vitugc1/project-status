# ── Neon DB ─────────────────────────────────────────────────────────────────
# Pooled connection string from Neon dashboard → Connection details → Prisma
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Better Auth ──────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-here"

# ── App URL ──────────────────────────────────────────────────────────────────
# Local: http://localhost:3000
# Vercel production: https://your-project.vercel.app  (or your custom domain)
# On Vercel this MUST be set as an environment variable in the dashboard.
# NEXT_PUBLIC_ prefix makes it available in client-side code (auth-client.ts).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
